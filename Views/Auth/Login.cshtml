<!doctype html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
    <title>ورود به سیستم</title>

    <link rel="stylesheet" href="~/css/fonts.css" />
    <link rel="stylesheet" href="~/css/main.css" />
    <link rel="stylesheet" href="~/css/responsive.css" />
</head>
<body>
    <div class="container">
        <div class="split-layout">
            <div class="split-left">
                <img src="~/assets/images/iran.png" alt="iran" />
            </div>

            <div class="split-right">
                <div class="auth-wrapper">
                    <h1 class="main-title">کندا ایده</h1>
                    <p class="main-subtitle">تجربه مهندسی خلاق</p>

                    <div class="auth-card">

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-error">
                                @ViewBag.Error
                            </div>
                        }

                        <form asp-controller="Auth" asp-action="Login" method="post">

                            <div class="form-group">
                                <input name="username"
                                       class="form-control"
                                       placeholder="نام کاربری"
                                       required />
                            </div>

                            <div class="form-group">
                                <input name="password"
                                       type="password"
                                       class="form-control"
                                       placeholder="رمز عبور"
                                       required />
                            </div>

                            <button type="submit" class="btn btn-primary">
                                ورود به سامانه
                            </button>
                        </form>

                        <div class="register-section">
                            <div class="divider-with-text">
                                <div class="divider-line"></div>
                                <span class="divider-text">آیا حساب کاربری ندارید؟</span>
                                <div class="divider-line"></div>
                            </div>

                            <a asp-controller="Auth" asp-action="Register" class="btn reg-btn">
                                ساخت حساب کاربری
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

</body>
</html>
