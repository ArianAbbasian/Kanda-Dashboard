@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "ورود به سیستم";
}

@section Scripts {
    <script src="~/js/pages/login.js"></script>

}

    <div class="container">
        <div class="split-layout">
            <div class="split-left">
                <img src="~/images/iran.png" alt="iran" />
            </div>

            <div class="split-right">
                <div class="auth-wrapper">
                    <h1 class="main-title">کندا ایده</h1>
                    <p class="main-subtitle">تجربه مهندسی خلاق</p>

                    <div class="auth-card">

                       

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-error">
                                @TempData["Error"]
                            </div>
                        }

                        <form id="loginForm" asp-controller="Auth" asp-action="Login" method="post" style="text-align: center">
                            <div class="form-group">
                                <input name="username"
                                       class="form-control"
                                       id="username"
                                       placeholder="نام کاربری"
                                       required />
                                <div class="validation-message validation-error hidden"
                                     id="usernameError">
                                    نام کاربری باید حداقل ۳ کاراکتر باشد
                                </div>
                            </div>

                            <div class="form-group">
                                <input name="password"
                                       type="password"
                                       class="form-control"
                                       id="password"
                                       placeholder="رمز عبور"
                                       required />
                                <div class="validation-message validation-error hidden"
                                     id="passwordError">
                                    رمز عبور باید حداقل ۶ کاراکتر باشد
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary">
                                ورود به سامانه
                            </button>
                            <div class="validation-message validation-error hidden"
                                 id="FormError">
                                نام کاربری / رمز عبور اشتباه است
                            </div>

                        </form>

                        <div class="register-section">
                            <div class="divider-with-text">
                                <div class="divider-line"></div>
                                <span class="divider-text">آیا حساب کاربری ندارید؟</span>
                                <div class="divider-line"></div>
                            </div>

                            <a asp-controller="Auth" asp-action="Register" class="reg-btn">
                                ساخت حساب کاربری
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
