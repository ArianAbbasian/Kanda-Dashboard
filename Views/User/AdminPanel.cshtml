@model IEnumerable<Login.Models.User>


@{
    Layout = "_Layout";
    ViewData["Title"] = "لیست کاربران";
}

<!doctype html>
<html lang="fa">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>لیست کاربران</title>

    <link rel="stylesheet" href="~/css/fonts.css" />
    <link rel="stylesheet" href="~/css/main.css" />
    <link rel="stylesheet" href="~/css/profile.css" />
    <link rel="stylesheet" href="~/css/AdminPanel.css" />
    <link rel="stylesheet" href="~/css/responsive.css" />
</head>
<body>
    
        <div class="profile-main-content">
            <input type="hidden" id="currentUsername" value="@ViewBag.CurrentUsername" />
            <div class="admin-panel-header">
            <h1 class="profile-main-title">لیست کاربران</h1>

            <div class="filter-section">
                <div class="filter-row">
                    <div class="filter-group">
                        <label for="filterName">نام / نام خانوادگی</label>
                        <input type="text"
                               id="filterName"
                               class="filter-input"
                               placeholder="جستجو بر اساس نام..." />
                    </div>

                    <div class="filter-group">
                        <label for="filterUsername">نام کاربری</label>
                        <input type="text"
                               id="filterUsername"
                               class="filter-input"
                               placeholder="نام کاربری..." />
                    </div>

                </div>
                @* Filters Section  *@

                <div class="filter-row">
                    <div class="filter-group">
                        <label for="filterProvince">استان</label>
                        <select id="filterProvince" class="filter-select">
                            <option value="">همه استان‌ها</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="filterCity">شهر</label>
                       <select id="filterCity" class="filter-select" disabled>
                            <option value="">ابتدا استان را انتخاب کنید</option>
                        </select>
                    </div>

                    <div class="filter-group filter-buttons">
                        <button id="applyFilterBtn" class="filter-btn apply-btn" onclick="applyFilters()">
                            <span class="filter-icon">🔍</span>
                            اعمال فیلتر
                        </button>
                        <button id="resetFilterBtn" class="filter-btn reset-btn" onclick="resetFilters()">
                            <span class="filter-icon">🔄</span>
                            پاک کردن
                        </button>
                    </div>
                </div>
            </div>

            
            <div class="tabs-container">
                <div class="tabs-header">
                    <button class="tab-btn active" data-tab="users-tab">
                        <span class="tab-icon">📋</span>
                        <span class="tab-text">لیست کاربران</span>
                        <span class="tab-badge" id="usersCountBadge">0</span>
                    </button>
                    <button class="tab-btn" data-tab="info-tab">
                        <span class="tab-icon">📈</span>
                        <span class="tab-text">نمودار ها </span>
                    </button>
                </div>

                <div class="tabs-content">
                    <!-- First Tab UsersList -->
                    <div class="tab-pane active" id="users-tab">
                        <div class="table-container">
                            <table class="table" id="usersTable">
                                <thead>
                                    <tr>
                                        <th>ردیف</th>
                                        <th>نام</th>
                                        <th>نام خانوادگی</th>
                                        <th>نام کاربری</th>
                                        <th>ایمیل</th>
                                        <th>شماره تماس</th>
                                        <th>استان</th>
                                        <th>شهر</th>
                                        <th>عملیات</th>
                                    </tr>
                                </thead>
                                <tbody id="tableBody">      
                                </tbody>
                            </table>
                        </div>

                        <div id="pagination" class="pagination">
                            <!-- Pagination -->
                        </div>
                    </div>

                    <!-- Second Tab (Charts) -->
                    <div class="tab-pane" id="info-tab">
                        <div class="charts-container">
                             <div class="charts-row">
                                <<!-- کارت نمودار پای -->
                                <div class="chart-card" id="pieChartCard">
                                    <h3 class="chart-title">📊 توزیع کاربران بر اساس استان</h3>
                                    <div class="chart-wrapper">
                                        <canvas id="pieChartProvinces" width="400" height="300"></canvas>
                                        <div class="no-data-message" id="pieChartNoData" style="display: none; text-align: center; padding: 50px; color: #999; font-size: 16px;">
                                            <span style="font-size: 3rem; display: block; margin-bottom: 10px;">📭</span>
                                            داده‌ای برای نمایش وجود ندارد
                                        </div>
                                    </div>
                                </div>
                                <div class="chart-card">
                                    <h3 class="chart-title">📊 تعداد و تنوع نوع کاربران</h3>
                                    <div class="chart-wrapper">
                                        <canvas id="pieChartRoles" width="300" height="200" class="roleChart"></canvas>
                                    </div>
                                </div>
                            </div>

                            <div class="charts-row">
                                <!-- کارت نمودار میله‌ای -->
                                <div class="chart-card full-width" id="barChartCard">
                                    <h3 class="chart-title">📊 توزیع کاربران در شهرها/استان‌ها</h3>
                                    <div class="chart-wrapper">
                                        <canvas id="barChartUsers" width="800" height="300"></canvas>
                                        <div class="no-data-message" id="barChartNoData" style="display: none; text-align: center; padding: 50px; color: #999; font-size: 16px;">
                                            <span style="font-size: 3rem; display: block; margin-bottom: 10px;">📭</span>
                                            داده‌ای برای نمایش وجود ندارد
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    

            <div class="action-buttons">
                <a asp-controller="User" asp-action="Profile" class="act-btn">بازگشت به پروفایل شخصی</a>
            </div>

        </div>

        <!-- =============================== Edit Modal ============================== -->
        <div id="editModal" class="modal">
            <div class="modal-content">
                <span class="close">&times;</span>
                <h3>ویرایش کاربر</h3>
                <form id="editForm">
                    <input type="hidden" id="editUserId" name="Id" />

                    <div class="form-group">
                        <label for="editFirstName">نام</label>
                        <input type="text" id="editFirstName" name="FirstName" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label for="editLastName">نام خانوادگی</label>
                        <input type="text" id="editLastName" name="LastName" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label for="editUsername">نام کاربری</label>
                        <input type="text" id="editUsername" name="Username" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label for="editEmail">ایمیل</label>
                        <input type="email" id="editEmail" name="Email" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label for="editPhone">شماره تماس</label>
                        <input type="text" id="editPhone" name="Phone" class="form-control" required />
                    </div>

                    <div class="form-group">
                        <label for="editPassword">رمز عبور</label>
                        <input type="password" id="editPassword" name="Password" class="form-control" placeholder="اگر نمی‌خواهید تغییر دهید، خالی بگذارید" />
                    </div>

                     <div class="form-group">
                        <label for="editProvince">استان</label>
                        <select id="editProvince" class="form-control" required>
                            <option value="">-- انتخاب استان --</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="editCity">شهر</label>
                        <select id="editCity" name="City" class="form-control" required>
                            <option value="">-- ابتدا استان را انتخاب کنید --</option>
                        </select>
                    </div>

                    <button type="submit" class="btn-primary full-width">ذخیره تغییرات</button>
                </form>
            </div>
        </div>

    </div>

    @section Scripts {
        <!-- Core -->
        <script src="~/js/core/pagination.js"></script>
        <script src="~/js/core/province-city.js"></script>
        <script src="~/js/core/toast.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <!-- Features -->
        <script src="~/js/features/filter.js"></script> 
        <script src="~/js/features/charts.js"></script>   
        <script src="~/js/features/user-crud.js"></script>
        <script src="~/js/features/tabs.js"></script>

        <!-- Page -->
        <script src="~/js/pages/adminPanel.js"></script>
    }
</body>
</html>

